{"allContent":{"docusaurus-plugin-content-docs":{"default":{"loadedVersions":[{"versionName":"current","label":"Next","banner":null,"badge":false,"noIndex":false,"className":"docs-version-current","path":"/docs","tagsPath":"/docs/tags","editUrl":"https://github.com/thinairthings/uix/tree/documentation/docs/docs","editUrlLocalized":"https://github.com/thinairthings/uix/tree/documentation/docs/i18n/en/docusaurus-plugin-content-docs/current","isLast":true,"routePriority":-1,"sidebarFilePath":"/home/lucasamberg/uix/docs/sidebars.ts","contentPath":"/home/lucasamberg/uix/docs/docs","contentPathLocalized":"/home/lucasamberg/uix/docs/i18n/en/docusaurus-plugin-content-docs/current","docs":[{"id":"defining-nodes/defineNodeSetRelationship","title":"Defining Node Set Relationships","description":"Similar to defining a Unique Relationship, defining Node Set relationships is extremely useful. For example: a user may only have one unique profile, but that profile will have anywhere from zero to unlimited posts","source":"@site/docs/defining-nodes/defineNodeSetRelationship.md","sourceDirName":"defining-nodes","slug":"/defining-nodes/defineNodeSetRelationship","permalink":"/docs/defining-nodes/defineNodeSetRelationship","draft":false,"unlisted":false,"editUrl":"https://github.com/thinairthings/uix/tree/documentation/docs/docs/defining-nodes/defineNodeSetRelationship.md","tags":[],"version":"current","sidebarPosition":4,"frontMatter":{"sidebar_position":4},"sidebar":"tutorialSidebar","previous":{"title":"Defining Unique Relationships","permalink":"/docs/defining-nodes/defineUniqueRelationship"},"next":{"title":"Defining Property Vectors","permalink":"/docs/defining-nodes/definePropertyVector"}},{"id":"defining-nodes/definePropertyVector","title":"Defining Property Vectors","description":"Arguably defining property vectors is one of the greatest draws to using Uix for AI focused implementations. By defining a property vector, your node will be automatically embedded on those properties, allowing for seamless vector search and AI searching implementations.","source":"@site/docs/defining-nodes/definePropertyVector.md","sourceDirName":"defining-nodes","slug":"/defining-nodes/definePropertyVector","permalink":"/docs/defining-nodes/definePropertyVector","draft":false,"unlisted":false,"editUrl":"https://github.com/thinairthings/uix/tree/documentation/docs/docs/defining-nodes/definePropertyVector.md","tags":[],"version":"current","sidebarPosition":5,"frontMatter":{"sidebar_position":5},"sidebar":"tutorialSidebar","previous":{"title":"Defining Node Set Relationships","permalink":"/docs/defining-nodes/defineNodeSetRelationship"},"next":{"title":"Functions","permalink":"/docs/category/functions"}},{"id":"defining-nodes/defineUniqueIndexes","title":"Defining Unique Indexes","description":"Defining unique indexes can be extremely useful for fetching nodes. For example if you want all users to have unique email addresses or usernames, you can define that as a unique index. This makes it extremely simple to fetch nodes using nodeKeys or indexes, and simultaneously makes it impossible for users to register an account with a username that already exists.","source":"@site/docs/defining-nodes/defineUniqueIndexes.md","sourceDirName":"defining-nodes","slug":"/defining-nodes/defineUniqueIndexes","permalink":"/docs/defining-nodes/defineUniqueIndexes","draft":false,"unlisted":false,"editUrl":"https://github.com/thinairthings/uix/tree/documentation/docs/docs/defining-nodes/defineUniqueIndexes.md","tags":[],"version":"current","sidebarPosition":2,"frontMatter":{"sidebar_position":2},"sidebar":"tutorialSidebar","previous":{"title":"Defining a Basic Node","permalink":"/docs/defining-nodes/defining-a-basic-node"},"next":{"title":"Defining Unique Relationships","permalink":"/docs/defining-nodes/defineUniqueRelationship"}},{"id":"defining-nodes/defineUniqueRelationship","title":"Defining Unique Relationships","description":"Defining unique relationships can be extremely usef